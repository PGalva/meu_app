<p style="color: green"><%= notice %> </p>

<% content_for :title, "Friends" %>

<table class = "table table-striped table-dark table-bordered">
  <thead>
  <tr>
    <th>First name</th>
    <th>Last name</th>
    <th>Email</th>
    <th>Phone</th>
    <th>Twitter</th>
    <th colspan="3"></th>
  </tr>
</thead>

<tbody id="friends">
  <% @friends.each do |friend| %>
    <tr>
        <td><%= friend.first_name %></td>
        <td><%= friend.last_name %></td>
        <td><%= friend.email %></td>
        <td><%= friend.phone %></td>
        <td><%= friend.twitter %></td>
        <td><%= link_to "Show this friend", friend, class: "btn btn-sm btn-outline-primary" %></td>
      </tr>
    <% end %>
</<tbody>
</table>

<%= link_to "New friend", new_friend_path, class:"btn btn-secondary" %>
